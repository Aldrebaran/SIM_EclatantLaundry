<Page
    x:Class="EclatantLaundry.LaporanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EclatantLaundry"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LaporanPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="ButtonSimpanStyle" 
            TargetType="Button">
            <Setter Property="Background" Value="#707B8C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="8">
                            <ContentPresenter 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#545D6A" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F4650" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0.0" Color="White" />
                <GradientStop Offset="0.3" Color="White" />
                <GradientStop Offset="0.7" Color="#FF7D4D" />
                <GradientStop Offset="1.0" Color="#FF5722" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,25">
                <Button 
                    x:Name="btnMingguan" 
                    Content="Mingguan" 
                    Width="180" 
                    Height="45" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Margin="5" 
                    Click="BtnMingguan_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button 
                    x:Name="btnBulanan" 
                    Content="Bulanan" 
                    Width="180" 
                    Height="45" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Margin="5" 
                    Click="BtnBulanan_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>


            <StackPanel 
                Grid.Row="1" 
                Orientation="Horizontal" 
                HorizontalAlignment="Center">

                <StackPanel 
                    x:Name="panelMinggu" 
                    Orientation="Horizontal">
                    <ComboBox 
                        x:Name="cbMinggu" 
                        Width="130" Height="35" 
                        VerticalContentAlignment="Center" 
                        Margin="5">
                        <ComboBoxItem Content="Minggu 1"/>
                        <ComboBoxItem Content="Minggu 2"/>
                        <ComboBoxItem Content="Minggu 3"/>
                        <ComboBoxItem Content="Minggu 4"/>
                    </ComboBox>
                </StackPanel>

                <ComboBox 
                    x:Name="cbBulan" 
                    Width="130" 
                    Height="35" 
                    VerticalContentAlignment="Center" 
                    Margin="5">
                    <ComboBoxItem Content="Januari"/>
                    <ComboBoxItem Content="Februari"/>
                    <ComboBoxItem Content="Maret"/>
                    <ComboBoxItem Content="April"/>
                    <ComboBoxItem Content="Mei"/>
                    <ComboBoxItem Content="Juni"/>
                    <ComboBoxItem Content="Juli"/>
                    <ComboBoxItem Content="Agustus"/>
                    <ComboBoxItem Content="September"/>
                    <ComboBoxItem Content="Oktober"/>
                    <ComboBoxItem Content="November"/>
                    <ComboBoxItem Content="Desember"/>
                </ComboBox>

                <ComboBox 
                    x:Name="cbTahun" 
                    Width="100" 
                    Height="35" 
                    VerticalContentAlignment="Center" 
                    Margin="5">
                    
                </ComboBox>

                <Button 
                    x:Name="btnTampilkan" 
                    Content="Tampilkan" 
                    Background="#1E90FF" 
                    Foreground="White" 
                    Width="110" 
                    Height="35" 
                    Margin="10,0,0,0" 
                    FontWeight="Bold"
                    Click="BtnTampilkan_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button 
                    x:Name="btnCetakPDF"
                    Content="Cetak PDF"
                    Style="{StaticResource ButtonSimpanStyle}"
                    Width="110"
                    Height="35"
                    Margin="5,0,0,0"
                    Click="BtnCetakPDF_Click" /> 
            </StackPanel>

            <UniformGrid
                Grid.Row="2"
                Columns="3"
                Margin="0,30,0,10"
                Width="850">

                <Border
                    Background="#C5D2E9"
                    CornerRadius="12"
                    Margin="8"
                    Padding="15"
                    BorderBrush="Black"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock 
                            Text="Total Barang Masuk"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="Black"/>

                        <StackPanel
                            Orientation="Horizontal"
                            Margin="0,15,0,0">
                            <TextBlock 
                                x:Name="txtTotalMasuk"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="Black"/>

                            <TextBlock 
                                Text=" Barang" 
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="Black"
                                VerticalAlignment="Bottom"
                                Margin="5,0,0,2" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Background="#F9DCC4"
                    CornerRadius="12"
                    Margin="8"
                    Padding="15"
                    BorderBrush="Black"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock 
                            Text="Total Barang Keluar"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="Black" />
                        <StackPanel
                            Orientation="Horizontal"
                            Margin="0,15,0,0">
                            <TextBlock 
                                x:Name="txtTotalKeluar"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="Black"/>

                            <TextBlock 
                                Text="Barang" 
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="Black"
                                VerticalAlignment="Bottom"
                                Margin="5,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Background="#D1FAD7"
                    CornerRadius="12"
                    Margin="8"
                    Padding="15"
                    BorderBrush="Black"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock 
                            Text="Stok Akhir"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="Black" />
                        <StackPanel
                            Orientation="Horizontal"
                            Margin="0,15,0,0">
                            <TextBlock 
                                x:Name="txtStokAkhir"
                                Text="0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="Black"/>

                            <TextBlock 
                                Text="Barang"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="Black"
                                VerticalAlignment="Bottom"
                                Margin="5,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <DataGrid
                Grid.Row="3"
                x:Name="dgLaporan"
                Margin="20 15,20,20"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                RowHeight="38"
                FontSize="14"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="#F0F0F0"
                IsReadOnly="True"
                MaxHeight="450"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding Tanggal}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nama Barang" Binding="{Binding NamaBarang}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Jenis Riwayat" Binding="{Binding Jenis}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Jumlah" Binding="{Binding Jumlah}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Satuan" Binding="{Binding Satuan}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
            
        </Grid>

    </Grid>
</Page>
