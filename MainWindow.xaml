<Window
    x:Class="EclatantLaundry.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Eclatant Laundry"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        From="0.0"
                        To="1.0"
                        Duration="0:0:0.5" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0.0" Color="#FF8C42" />
                <GradientStop Offset="0.5" Color="White" />
                <GradientStop Offset="1.0" Color="#FF8C42" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border
            Width="450"
            Height="580"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="30">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="40"
                    Opacity="0.3"
                    ShadowDepth="0" />
            </Border.Effect>

            <StackPanel
                x:Name="MainContainer"
                Margin="50"
                VerticalAlignment="Center">
                <Image
                    Height="60"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Source="D:\Tugas\SIM\EclatantLaundry\Assets\Logo.png" />
                <TextBlock
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    FontWeight="Bold"
                    Text="LAUNDRY &amp; DRY CLEANING" />

                <TextBlock
                    Margin="0,0,0,5"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="Selamat datang kembali!" />
                <TextBlock
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    Foreground="Gray"
                    Text="Masukkan akun Anda untuk melanjutkan" />

                <Border
                    Height="50"
                    Margin="0,0,0,15"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="15">
                    <StackPanel
                        Margin="15,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            Foreground="Gray"
                            Text="👤" />
                        <TextBox
                            x:Name="txtUsername"
                            Width="300"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="Gray"
                            GotFocus="TxtUsername_GotFocus"
                            LostFocus="TxtUsername_LostFocus"
                            Text="Username" />
                    </StackPanel>
                </Border>

                <Border
                    Height="50"
                    Margin="0,0,0,5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="15">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            Text="🔒" />

                        <TextBlock
                            x:Name="txtPasswordPlaceholder"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="Password" />

                        <PasswordBox
                            x:Name="txtPassword"
                            Grid.Column="1"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            GotFocus="TxtPassword_GotFocus"
                            LostFocus="TxtPassword_LostFocus" />
                    </Grid>
                </Border>

                <TextBlock
                    Margin="0,10,0,25"
                    HorizontalAlignment="Right"
                    Cursor="Hand"
                    FontSize="10"
                    Foreground="Blue"
                    MouseLeftButtonUp="ForgotPassword_Click"
                    Text="Lupa Password ?">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.6" />
                                    <Setter Property="TextDecorations" Value="Underline" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button
                    x:Name="btnLogin"
                    Height="50"
                    Margin="0,10,0,0"
                    Background="#FF5722"
                    BorderThickness="0"
                    Click="Login_Click"
                    Content="Masuk"
                    Cursor="Hand"
                    FontWeight="Bold"
                    Foreground="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="btnBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background" Value="#E64A19" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btnBorder" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="12"
                        Foreground="Gray"
                        Text="Belum punya akun? " />
                    <TextBlock
                        Cursor="Hand"
                        FontWeight="Bold"
                        Foreground="Blue"
                        MouseLeftButtonUp="Register_Click"
                        Text="Daftar Sekarang">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Setter Property="TextDecorations" Value="Underline" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>